---
layout: null
---
[
{% for post in site.posts %}
  {
    "title"    : {{ post.title | jsonify }},
    "category" : "blog",
    "tags"     : {{ post.tags | join: ', ' | jsonify }},
    "url"      : {{ post.url | jsonify }},
    "date"     : {{ post.date | date: "%Y-%m-%d" | jsonify }},
    "content"  : {{ post.content | strip_html | strip_newlines | jsonify }}
  } {% unless forloop.last %},{% endunless %}
{% endfor %}
{% for p in site.wiki %}
  ,{
    "title"    : {{ p.title | jsonify }},
    "category" : "wiki",
    "tags"     : {{ p.tags | join: ', ' | jsonify }},
    "url"      : {{ p.url | jsonify }},
    "date"     : {{ p.updated | default: p.date | date: "%Y-%m-%d" | jsonify }},
    "content"  : {{ p.content | strip_html | strip_newlines | jsonify }}
  }
{% endfor %}
{% for page in site.pages %}
  {% if page.title and page.content and page.url != '/search.html' and page.url != '/wiki/' %}
  ,{
    "title"    : {{ page.title | jsonify }},
    "category" : {{ page.category | jsonify }},
    "tags"     : {{ page.tags | join: ', ' | jsonify }},
    "url"      : {{ page.url | jsonify }},
    "date"     : "",
    "content"  : {{ page.content | strip_html | strip_newlines | jsonify }}
  }
  {% endif %}
{% endfor %}
]
